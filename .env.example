# Synthetic API Configuration
# Get your API key from: https://synthetic.new/
SYNTHETIC_API_KEY=your-api-key-here

# Optional: Default model to use (avoids typing -m every time)
# Run "jarvis list-models" to see available models
DEFAULT_MODEL=hf:nvidia/Kimi-K2.5-NVFP4

# Optional: Custom base URL (defaults to synthetic.new)
# SYNTHETIC_BASE_URL=https://api.synthetic.new/openai/v1
