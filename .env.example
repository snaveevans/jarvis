# Synthetic API Configuration
# Get your API key from: https://synthetic.new/
# LLM_PROVIDER=synthetic
# DEFAULT_MODEL=hf:nvidia/Kimi-K2.5-NVFP4

# Synthetic provider
SYNTHETIC_API_KEY=your-synthetic-api-key-here
# SYNTHETIC_BASE_URL=https://api.synthetic.new/openai/v1
# SYNTHETIC_DEFAULT_MODEL=hf:nvidia/Kimi-K2.5-NVFP4

# MiniMax provider
# MINIMAX_API_KEY=your-minimax-api-key-here
# MINIMAX_BASE_URL=https://api.minimax.io/v1
# MINIMAX_DEFAULT_MODEL=MiniMax-M2.5

# Optional aliases for MiniMax OpenAI-compatible usage
# OPENAI_API_KEY=your-minimax-api-key-here
# OPENAI_BASE_URL=https://api.minimax.io/v1

# Generic overrides for currently selected provider
# LLM_API_KEY=provider-api-key-override
# LLM_BASE_URL=https://provider-base-url/v1
# OPENAI_COMPATIBLE_DEFAULT_MODEL=

# Optional global model override for currently selected provider
# DEFAULT_MODEL=

# Optional: Logging level for tool-call observability output
# JARVIS_LOG_LEVEL=info

# Optional: Log tool-call observability output to a file (stdout logging stays enabled)
# JARVIS_LOG_FILE=./jarvis.log

# Telegram bot token (get from @BotFather on Telegram)
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Optional: Comma-separated Telegram user IDs allowed to interact with the bot.
# When set, messages from unlisted users are silently ignored.
# Find your user ID by messaging @userinfobot on Telegram.
# TELEGRAM_ALLOWED_USER_IDS=123456789,987654321
