{
  "llm": {
    "provider": "minimax",
    "defaultModel": "",
    "defaultPrompt": "",
    "providers": {
      "synthetic": {
        "apiKey": "",
        "baseUrl": "https://api.synthetic.new/openai/v1",
        "defaultModel": "hf:nvidia/Kimi-K2.5-NVFP4"
      },
      "minimax": {
        "apiKey": "",
        "baseUrl": "https://api.minimax.io/v1",
        "defaultModel": "MiniMax-M2.5"
      },
      "openaiCompatible": {
        "apiKey": "",
        "baseUrl": "",
        "defaultModel": ""
      }
    }
  },
  "telegram": {
    "botToken": "",
    "allowedUserIds": []
  },
  "memory": {
    "enabled": true,
    "dir": "",
    "archiveRetentionDays": 14,
    "summaryWindowMinutes": 30,
    "autoSummarize": false,
    "autoContextMaxResults": 5,
    "autoContextMaxTokens": 500,
    "searchMaxLimit": 20,
    "searchDefaultLimit": 5,
    "recentDefaultLimit": 10,
    "minSummaryTokens": 200,
    "tokenEstimationCharsPerToken": 4
  },
  "logging": {
    "level": "info",
    "file": ""
  },
  "history": {
    "enabled": true,
    "dbPath": "data/session-history.db",
    "retentionHours": 72,
    "rehydrateMaxMessages": 200
  },
  "workers": {
    "searchPoolSize": 2,
    "shellPoolSize": 3
  },
  "search": {
    "provider": "brave",
    "defaultLimit": 5,
    "maxLimit": 10,
    "timeoutMs": 15000,
    "brave": {
      "apiKey": "",
      "baseUrl": "https://api.search.brave.com/res/v1/web/search"
    },
    "synthetic": {
      "apiKey": "",
      "baseUrl": "https://api.synthetic.new/v2/search"
    }
  },
  "tools": {
    "maxParallel": 5,
    "maxIterations": 20,
    "maxOutputCharacters": 50000,
    "maxOutputLines": 2000,
    "maxLineLength": 2000,
    "timeoutMs": 120000,
    "maxGlobResults": 1000,
    "maxGrepMatches": 1000,
    "maxReadLines": 2000,
    "eventStoreSize": 500
  }
